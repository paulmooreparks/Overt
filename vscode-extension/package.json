{
    "name": "overt-language",
    "displayName": "Overt",
    "description": "Syntax highlighting and language configuration for Overt",
    "version": "0.1.0",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.70.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "overt",
                "aliases": [
                    "Overt",
                    "overt"
                ],
                "extensions": [
                    ".ov"
                ],
                "icon": {
                    "light": "./icon.png",
                    "dark": "./icon.png"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "overt",
                "scopeName": "source.overt",
                "path": "./syntaxes/overt.tmLanguage.json"
            }
        ]
    }
}
