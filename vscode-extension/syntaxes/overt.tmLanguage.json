{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Overt",
    "scopeName": "source.overt",
    "fileTypes": ["ov"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#annotations" },
        { "include": "#effect-row" },
        { "include": "#await-postfix" },
        { "include": "#discard" },
        { "include": "#operators" },
        { "include": "#types" },
        { "include": "#builtin-functions" },
        { "include": "#functions" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.overt",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.overt",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.overt",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.overt",
                            "match": "\\\\."
                        },
                        {
                            "name": "meta.embedded.expression.overt",
                            "begin": "\\$\\{",
                            "end": "\\}",
                            "beginCaptures": {
                                "0": { "name": "punctuation.definition.template-expression.begin.overt" }
                            },
                            "endCaptures": {
                                "0": { "name": "punctuation.definition.template-expression.end.overt" }
                            },
                            "patterns": [
                                { "include": "$self" }
                            ]
                        },
                        {
                            "name": "variable.other.interpolation.overt",
                            "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.integer.hex.overt",
                    "match": "\\b0x[0-9A-Fa-f_]+\\b"
                },
                {
                    "name": "constant.numeric.integer.binary.overt",
                    "match": "\\b0b[01_]+\\b"
                },
                {
                    "name": "constant.numeric.float.overt",
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.overt",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.overt",
                    "comment": "Control flow. `each` is the deprecated-but-still-parseable spelling for `for each x in`; bare `for x in` is the canonical form.",
                    "match": "\\b(if|else|match|for|each|in|while|loop|break|continue|return|parallel|race|trace|with)\\b"
                },
                {
                    "name": "storage.type.declaration.overt",
                    "comment": "Declaration / modifier keywords. `binds` and `from` are contextual (only meaningful inside `extern fn`), but recognized as keywords for highlighting.",
                    "match": "\\b(fn|let|mut|record|enum|type|module|use|as|pub|extern|unsafe|where|binds|from|await)\\b"
                },
                {
                    "name": "constant.language.boolean.overt",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.overt",
                    "comment": "Built-in tagged-union constructors. Resolved as factory calls returning Result/Option markers.",
                    "match": "\\b(Ok|Err|Some|None)\\b"
                }
            ]
        },
        "annotations": {
            "patterns": [
                {
                    "name": "storage.modifier.annotation.overt",
                    "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
                }
            ]
        },
        "effect-row": {
            "patterns": [
                {
                    "name": "meta.effect-row.overt",
                    "comment": "Effect row syntax: !{io}, !{io, async}, !{E} (row-polymorphic). Effect-variable identifiers are uppercase; concrete effect names are lowercase.",
                    "begin": "!\\{",
                    "end": "\\}",
                    "beginCaptures": {
                        "0": { "name": "keyword.operator.effect.overt" }
                    },
                    "endCaptures": {
                        "0": { "name": "keyword.operator.effect.overt" }
                    },
                    "patterns": [
                        {
                            "name": "support.type.effect.overt",
                            "match": "\\b(io|async|inference|fails)\\b"
                        },
                        {
                            "name": "variable.other.effect.overt",
                            "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                        }
                    ]
                }
            ]
        },
        "await-postfix": {
            "patterns": [
                {
                    "comment": "Postfix .await is a single syntactic unit (DESIGN.md §9). Highlighted as a control keyword to mirror the JS / Rust convention.",
                    "match": "(\\.)(await)\\b",
                    "captures": {
                        "1": { "name": "punctuation.accessor.overt" },
                        "2": { "name": "keyword.control.async.overt" }
                    }
                }
            ]
        },
        "discard": {
            "patterns": [
                {
                    "comment": "Bare `_` as a let-target or pattern: discards the value, doesn't bind a name.",
                    "name": "variable.language.discard.overt",
                    "match": "(?<![a-zA-Z0-9_])_(?![a-zA-Z0-9_])"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.pipe-propagate.overt",
                    "match": "\\|>\\?"
                },
                {
                    "name": "keyword.operator.pipe.overt",
                    "match": "\\|>"
                },
                {
                    "name": "keyword.operator.propagate.overt",
                    "match": "\\?"
                },
                {
                    "name": "keyword.operator.arrow.overt",
                    "match": "=>|->"
                },
                {
                    "name": "keyword.operator.comparison.overt",
                    "match": "==|!=|<=|>="
                },
                {
                    "name": "keyword.operator.logical.overt",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.assignment.overt",
                    "match": "="
                },
                {
                    "name": "keyword.operator.relational.overt",
                    "match": "<|>"
                },
                {
                    "name": "keyword.operator.arithmetic.overt",
                    "match": "\\+|-|\\*|/|%"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.overt",
                    "comment": "Stdlib types: real primitives (Int, Int64, Float, Bool, String, Unit), nominal stdlib generics (Option, Result, List, Map, Set, Task), error types, and FFI-boundary types. Not strictly minimal — kept permissive so common BCL bridges (Int32, Byte, Char) also highlight cleanly.",
                    "match": "\\b(Int|Int32|Int64|Float|Bool|String|Byte|Char|Unit|Option|Result|List|Map|Set|Seq|Task|CString|Ptr|Index|TraceEvent|RaceAllFailed|OvertError|IoError|HttpError|JsonError|ParseError)\\b"
                },
                {
                    "name": "entity.name.type.overt",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "builtin-functions": {
            "patterns": [
                {
                    "name": "support.function.builtin.overt",
                    "comment": "Prelude functions, ambient in every module without `use`. Mirrors Stdlib.cs entries; keep this list in sync when adding prelude exports.",
                    "match": "\\b(println|eprintln|print|args|size|length|len|map|filter|fold|try_map|par_map|all|any)(?=\\s*\\()"
                },
                {
                    "name": "support.function.namespace.overt",
                    "comment": "Module-qualified stdlib calls (`String.chars`, `Int.range`, `List.at`, etc.). Uppercase namespace + lowercase member.",
                    "match": "\\b(String|Int|List|Map|Set|Trace|CString)\\.[a-z_][a-zA-Z0-9_]*(?=\\s*\\()"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.definition.overt",
                    "match": "(?<=\\bfn\\s)[a-z_][a-zA-Z0-9_]*"
                },
                {
                    "name": "entity.name.function.call.overt",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*(?=\\s*\\()"
                }
            ]
        }
    }
}
