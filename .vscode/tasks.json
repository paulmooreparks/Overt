{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "publish-local",
      "detail": "Pack Overt + Overt.Build on the local channel and reinstall the global tool. Ctrl-Shift-B.",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/publish-channel.ps1"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Overt.sln",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "revealProblems": "onProblem",
        "clear": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/Overt.sln",
        "--nologo"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "clear": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "clean",
      "type": "process",
      "command": "dotnet",
      "args": [
        "clean",
        "${workspaceFolder}/Overt.sln"
      ],
      "presentation": {
        "reveal": "silent",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "rebuild",
      "dependsOrder": "sequence",
      "dependsOn": ["clean", "build"],
      "problemMatcher": []
    }
  ]
}
