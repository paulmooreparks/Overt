<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet config used only by scripts/publish-channel.* when they
  invoke `dotnet tool install` to put the Overt package on PATH.
  Passing this via the `configfile` option makes NuGet ignore the
  user-profile config for the single invocation (documented behavior),
  so a restrictive user-level packageSourceMapping on the developer's
  machine can't block the install.

  The Overt package itself comes from the dist/ folder that
  publish-channel wires in via the `add-source` option. nuget.org is
  declared here so transitive dependencies resolve. No
  packageSourceMapping is declared on purpose: without a mapping
  element, every source is free to serve every package, which is
  what we want for a one-shot tool install.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
