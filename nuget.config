<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-scoped NuGet source mapping.

  The Overt.Build MSBuild task project needs to reference
  Microsoft.Build.Utilities.Core and Microsoft.Build.Framework to subclass
  Microsoft.Build.Utilities.Task. Some contributor environments have a
  user-level NuGet.Config with an explicit packageSourceMapping allowlist
  that doesn't cover these packages; this file extends the mapping for
  just this repo without modifying the user's global config.

  Patterns use `Microsoft.Build.*` so related packages (Tasks.Core, etc.)
  flow through without further edits.
-->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="Microsoft.Build.*" />
      <package pattern="Microsoft.NET.StringTools" />
      <package pattern="System.Configuration.ConfigurationManager" />
      <package pattern="System.Security.Cryptography.ProtectedData" />
    </packageSource>
  </packageSourceMapping>
</configuration>
