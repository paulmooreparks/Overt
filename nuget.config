<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-scoped NuGet configuration.

  Contributors whose user-profile NuGet.Config declares a restrictive
  packageSourceMapping (an explicit allowlist of package IDs) would
  otherwise see restore failures here: packageSourceMapping in a more
  specific config *replaces* the mapping from less specific configs
  for the same source, and Overt transitively pulls in Microsoft.Build,
  Microsoft.CodeAnalysis, xunit, and a long tail of BCL packages that
  no narrow allowlist will cover.

  This file declares a wildcard mapping for nuget.org so that every
  package the solution needs resolves on both CI runners (which have
  no user profile) and contributor machines with strict profiles.
  nuget.org is the only configured source, so the wildcard does not
  add any new trust surface.
-->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
