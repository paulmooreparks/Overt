<?xml version="1.0" encoding="utf-8"?>
<!--
  Overt MSBuild integration.

  Importing this file into a C# project makes `.ov` files build alongside
  `.cs` files. Each `.ov` is transpiled to C# via the `OvertTranspileTask`
  below, the resulting `.g.cs` is added to the `Compile` item group, and
  Csc picks it up in the normal build. A `ProjectReference` to
  `Overt.Runtime` is added automatically so generated code resolves
  `Overt.Runtime.Unit`, `Result<,>`, etc. without the consumer having to
  add it by hand.

  Opt-in usage:
    <Import Project="path/to/Overt.Build.targets" />

  Defaults:
    - Every `*.ov` under the project directory becomes an `<OvertCompile>`
      item (disable via `<EnableDefaultOvertCompileItems>false</...>`).
    - Generated `.cs` files land in `$(IntermediateOutputPath)overt/`.
-->
<Project>

  <PropertyGroup>
    <EnableDefaultOvertCompileItems Condition=" '$(EnableDefaultOvertCompileItems)' == '' ">true</EnableDefaultOvertCompileItems>
  </PropertyGroup>

  <ItemGroup Condition=" '$(EnableDefaultOvertCompileItems)' == 'true' ">
    <OvertCompile Include="**\*.ov" Exclude="$(DefaultItemExcludes);$(DefaultExcludesInProjectFolder)" />
  </ItemGroup>

  <!-- Resolve the task DLL in two supported layouts:
       1. In-repo dev: the task DLL is copied next to this targets file
          via the project's build output. `$(MSBuildThisFileDirectory)Overt.Build.dll`
          exists in that case.
       2. NuGet package: this targets file lives at `build/Overt.Build.targets`
          and the task DLL is at `tasks/net9.0/Overt.Build.dll`. Fall back
          to that path.
       -->
  <PropertyGroup>
    <_OvertBuildTaskDll Condition=" Exists('$(MSBuildThisFileDirectory)Overt.Build.dll') ">$(MSBuildThisFileDirectory)Overt.Build.dll</_OvertBuildTaskDll>
    <_OvertBuildTaskDll Condition=" '$(_OvertBuildTaskDll)' == '' ">$(MSBuildThisFileDirectory)..\tasks\net9.0\Overt.Build.dll</_OvertBuildTaskDll>
  </PropertyGroup>

  <UsingTask
    TaskName="Overt.Build.OvertTranspileTask"
    AssemblyFile="$(_OvertBuildTaskDll)" />

  <!--
    Runs before CoreCompile so the Csc invocation sees the generated
    .g.cs files. Inputs/Outputs drive incremental build: if a .ov
    hasn't changed and its .g.cs exists, MSBuild skips us.

    OvertGeneratedOutputPath defaults inside the target so the fallback
    resolves AFTER the SDK has finished populating $(IntermediateOutputPath);
    evaluating it in a top-level PropertyGroup at import time would see
    an empty string and drop generated files in the project root.
  -->
  <Target
    Name="OvertTranspile"
    BeforeTargets="CoreCompile"
    Condition=" '@(OvertCompile)' != '' "
    Inputs="@(OvertCompile)"
    Outputs="@(OvertCompile->'$(OvertGeneratedOutputPath)%(Filename).g.cs')">

    <PropertyGroup>
      <OvertGeneratedOutputPath Condition=" '$(OvertGeneratedOutputPath)' == '' ">$(IntermediateOutputPath)overt\</OvertGeneratedOutputPath>
    </PropertyGroup>

    <OvertTranspileTask
      SourceFiles="@(OvertCompile)"
      OutputDirectory="$(OvertGeneratedOutputPath)">
      <Output TaskParameter="GeneratedFiles" ItemName="Compile" />
      <Output TaskParameter="GeneratedFiles" ItemName="FileWrites" />
    </OvertTranspileTask>
  </Target>

</Project>
